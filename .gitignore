# ─────────────────────────────────────────────
# Python
# ─────────────────────────────────────────────
__pycache__/
*.py[cod]
*.pyo
*.pyd
*.so
*.egg
*.egg-info/
dist/
build/
.eggs/
.Python
pip-wheel-metadata/
.pytest_cache/
.mypy_cache/
.ruff_cache/

# Virtual environments
venv/
.venv/
env/
.env/

# ─────────────────────────────────────────────
# MAVProxy / ArduPilot runtime files
# ─────────────────────────────────────────────
# Telemetry logs — large binary files (can be 25–50 MB per session)
simulation/mav.tlog
simulation/mav.tlog.raw
simulation/*.tlog
simulation/*.tlog.raw

# ArduPilot EEPROM / dataflash logs
*.bin
*.log
eeprom.bin
logs/

# MAVProxy temp files
*.mav

# ─────────────────────────────────────────────
# Wireshark / tshark
# ─────────────────────────────────────────────
# Keep attack capture pcaps (small, part of results)
# Ignore any temp captures
*.pcapng
*.tmp.pcap

# ─────────────────────────────────────────────
# ML model artefacts (regenerated by training)
# ─────────────────────────────────────────────
detection/models/baseline.pkl
detection/models/*.pkl
detection/models/*.joblib

# Detection runtime logs (regenerated each run)
detection/results/alerts.log
detection/results/*.log

# ─────────────────────────────────────────────
# Reports — Word documents
# Keep them for version history
# (remove this block if you don't want .docx tracked)
# ─────────────────────────────────────────────
# reports/*.docx   ← intentionally NOT ignored — kept in repo

# ─────────────────────────────────────────────
# Reference repo — large video files
# (The .mkv files in reference/ are git-lfs pointers, 133 bytes each — safe to include)
# ─────────────────────────────────────────────
# reference/**/*.mkv   ← NOT ignored (they're tiny pointer files, not real videos)

# ─────────────────────────────────────────────
# OS / Editor
# ─────────────────────────────────────────────
.DS_Store
Thumbs.db
.idea/
.vscode/
*.swp
*.swo
*~

# ─────────────────────────────────────────────
# Secrets / Keys
# ─────────────────────────────────────────────
*.pem
*.key
*.secret
.env
secrets.txt
